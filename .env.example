# --- Optional: SNCF live delays (Navitia) ---
# SNCF_NAVITIA_TOKEN=

# --- Email briefing (Gmail SMTP via App Password) ---
# 1. Enable 2-step verification on the Gmail account.
# 2. Generate an App Password at https://myaccount.google.com/apppasswords
# 3. Fill these:
GMAIL_USER=daitenkutarojurai@gmail.com
GMAIL_APP_PASSWORD=
EMAIL_TO=daitenkutarojurai@gmail.com
# Optional pretty "From" header — defaults to "Glaces en Seine <GMAIL_USER>"
# EMAIL_FROM="Glaces en Seine <daitenkutarojurai@gmail.com>"

# --- Public URL of the deployed site (used in email CTA + as image base) ---
NEXT_PUBLIC_SITE_URL=https://crepesforecast.vercel.app

# --- Cron secret (Vercel sets this automatically when you create a cron) ---
# Generate any random string and set it in Vercel project settings; cron jobs
# will be invoked with `Authorization: Bearer $CRON_SECRET`.
CRON_SECRET=
